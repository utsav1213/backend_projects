    "body-parser": "^1.20.2",
    "bullmq": "^1.81.0",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "express-rate-limit": "^6.8.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.0",
    "pino": "^8.9.0",
    "pino-http": "^8.0.0",
